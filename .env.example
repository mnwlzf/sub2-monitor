SUB2_MONITOR_APP_NAME="Sub2 Monitor"
SUB2_MONITOR_ENV=development
SUB2_MONITOR_HOST=0.0.0.0
SUB2_MONITOR_PORT=8000
SUB2_MONITOR_DATABASE_URL=sqlite:///./data/sub2-monitor.db
SUB2_MONITOR_SECRET_KEY=replace-with-a-long-random-secret
SUB2_MONITOR_BOOTSTRAP_USERNAME=admin
SUB2_MONITOR_BOOTSTRAP_PASSWORD=change-this-password
SUB2_MONITOR_SESSION_COOKIE_NAME=sub2_monitor_session
SUB2_MONITOR_SESSION_TTL_SECONDS=43200
SUB2_MONITOR_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

